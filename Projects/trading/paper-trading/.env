# Tradovate API credentials (get from https://demo.tradovateapi.com/v1)
TRADOVATE_API_KEY=your_tradovate_api_key_here
TRADOVATE_API_SECRET=your_tradovate_api_secret_here
# Base URL for Tradovate (use demo for testing)
TRADOVATE_BASE_URL=https://demo.tradovateapi.com/v1

# Flask secret key
SECRET_KEY=dev-secret-key-change-in-production

# Database connection (if using PostgreSQL via docker-compose)
POSTGRES_USER=papertrader
POSTGRES_PASSWORD=papertrader
POSTGRES_DB=papertrading
DATABASE_URL=postgresql://papertrader:papertrader@db:5432/papertrading