# Tradovate historical futures candles
# Use demo for testing. Live accounts normally use https://live.tradovateapi.com/v1.
TRADOVATE_BASE_URL=https://demo.tradovateapi.com/v1
TRADOVATE_USERNAME=your_tradovate_username_here
TRADOVATE_PASSWORD=your_tradovate_password_here
TRADOVATE_APP_ID=papertradingwebapp
TRADOVATE_APP_VERSION=1.0.0
TRADOVATE_DEVICE_ID=papertrading-web
# Optional API app credentials when your Tradovate app registration provides them.
TRADOVATE_CID=
TRADOVATE_SECRET=
# Legacy fallback names supported by the app. Prefer TRADOVATE_USERNAME/PASSWORD above.
TRADOVATE_API_KEY=
TRADOVATE_API_SECRET=

# E*TRADE OAuth 1.0a credentials
# Use sandbox for API syntax/data-shape testing. Use live only after E*TRADE API agreement,
# market data agreement, and access token flow are complete.
ETRADE_ENV=sandbox
ETRADE_CONSUMER_KEY=your_etrade_consumer_key_here
ETRADE_CONSUMER_SECRET=your_etrade_consumer_secret_here
# Generated by the app's Live Data -> Connect E*TRADE OAuth flow.
ETRADE_ACCESS_TOKEN=your_etrade_access_token_here
ETRADE_ACCESS_TOKEN_SECRET=your_etrade_access_token_secret_here

# Polygon historical aggregate data
POLYGON_BASE_URL=https://api.polygon.io
POLYGON_API_KEY=your_polygon_api_key_here

# Flask secret key
SECRET_KEY=dev-secret-key-change-in-production
CORS_ORIGINS=*
# Host port used by docker-compose to expose the Flask backend.
BACKEND_PORT=5001
# Optional override for container/server mounts. Leave unset for local python app.py.
# PROVIDER_ENV_PATH=/app/.env

# Database connection (if using PostgreSQL via docker-compose)
POSTGRES_USER=papertrader
POSTGRES_PASSWORD=papertrader
POSTGRES_DB=papertrading
DATABASE_URL=postgresql://papertrader:papertrader@db:5432/papertrading
